---
interface Props {
  url?: string;
  title?: string;
}

const { url = 'https://donate.example.org', title = '' } = Astro.props;
---

<div class="modern-frame">
  <!-- Minimal browser chrome -->
  <div class="modern-toolbar">
    <div class="modern-dots">
      <span class="modern-dot modern-dot-red"></span>
      <span class="modern-dot modern-dot-yellow"></span>
      <span class="modern-dot modern-dot-green"></span>
    </div>
    <div class="modern-urlbar">
      <svg class="modern-lock" viewBox="0 0 12 14" width="10" height="12">
        <rect x="2" y="6" width="8" height="6" rx="1" fill="#34a853" />
        <path d="M4 6V4.5a2 2 0 014 0V6" stroke="#34a853" stroke-width="1.2" fill="none" />
      </svg>
      <span class="modern-url">{url}</span>
    </div>
  </div>

  <!-- Content -->
  <div class="modern-content">
    <slot />
  </div>
</div>

<style>
  .modern-frame {
    width: 100%;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .modern-toolbar {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    background: #fafafa;
    border-bottom: 1px solid #e5e7eb;
    gap: 10px;
  }

  .modern-dots {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .modern-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .modern-dot-red { background: #ff5f57; }
  .modern-dot-yellow { background: #ffbd2e; }
  .modern-dot-green { background: #28c840; }

  .modern-urlbar {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 6px;
    background: #f1f3f4;
    border-radius: 8px;
    padding: 5px 10px;
    min-width: 0;
  }

  .modern-lock {
    flex-shrink: 0;
  }

  .modern-url {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 12px;
    color: #555;
  }

  .modern-content {
    background: #fff;
    min-height: 60px;
    line-height: 0;
    overflow: hidden;
  }

  .modern-content :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .modern-content :global(iframe) {
    width: 100%;
    display: block;
  }
</style>
