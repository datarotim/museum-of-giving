---
interface Props {
  title?: string;
  url?: string;
}

const { title, url } = Astro.props;
---

<div class="iphone-frame">
  <div class="iphone-body">
    <!-- Notch -->
    <div class="iphone-notch-area">
      <div class="iphone-time">9:41</div>
      <div class="iphone-notch">
        <div class="iphone-camera"></div>
      </div>
      <div class="iphone-status-icons">
        <svg viewBox="0 0 17 12" width="15" height="10" class="iphone-signal">
          <rect x="0" y="8" width="3" height="4" rx="0.5" fill="#1a1a1a" />
          <rect x="4.5" y="5" width="3" height="7" rx="0.5" fill="#1a1a1a" />
          <rect x="9" y="2" width="3" height="10" rx="0.5" fill="#1a1a1a" />
          <rect x="13.5" y="0" width="3" height="12" rx="0.5" fill="#1a1a1a" />
        </svg>
        <svg viewBox="0 0 16 12" width="14" height="10" class="iphone-wifi">
          <path d="M8 10a1.5 1.5 0 110 .01" fill="#1a1a1a" />
          <path d="M4.5 7.5a5 5 0 017 0" stroke="#1a1a1a" stroke-width="1.2" fill="none" />
          <path d="M2 5a8 8 0 0112 0" stroke="#1a1a1a" stroke-width="1.2" fill="none" />
        </svg>
        <svg viewBox="0 0 26 12" width="22" height="10" class="iphone-battery">
          <rect x="0" y="1" width="22" height="10" rx="2" stroke="#1a1a1a" stroke-width="1" fill="none" />
          <rect x="23" y="3.5" width="2" height="5" rx="1" fill="#1a1a1a" />
          <rect x="2" y="3" width="18" height="6" rx="1" fill="#1a1a1a" />
        </svg>
      </div>
    </div>

    {title && (
      <div class="iphone-header">
        <span class="iphone-header-title">{title}</span>
      </div>
    )}

    <!-- Screen content -->
    <div class="iphone-screen">
      <slot />
    </div>

    <!-- Home indicator -->
    <div class="iphone-home-indicator">
      <div class="iphone-home-bar"></div>
    </div>
  </div>
</div>

<style>
  .iphone-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .iphone-body {
    position: relative;
    width: 100%;
    max-width: 100%;
    background: #000;
    border-radius: 24px;
    padding: 3px;
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.3),
      0 8px 40px rgba(0, 0, 0, 0.15),
      inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    overflow: hidden;
  }

  /* Notch area / status bar */
  .iphone-notch-area {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 8px 20px 4px;
    background: #fff;
    border-radius: 22px 22px 0 0;
    position: relative;
  }

  .iphone-time {
    font-family: -apple-system, 'SF Pro Display', 'Helvetica Neue', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    width: 54px;
    z-index: 1;
  }

  .iphone-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 28px;
    background: #000;
    border-radius: 0 0 18px 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .iphone-camera {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #1a1a2e;
    box-shadow:
      inset 0 0 2px rgba(0, 100, 200, 0.3),
      0 0 1px rgba(0, 0, 0, 0.5);
  }

  .iphone-status-icons {
    display: flex;
    align-items: center;
    gap: 4px;
    z-index: 1;
  }

  .iphone-header {
    background: #fff;
    padding: 6px 16px;
    border-bottom: 0.5px solid #e5e5e5;
  }

  .iphone-header-title {
    font-family: -apple-system, 'SF Pro Display', 'Helvetica Neue', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
  }

  /* Screen */
  .iphone-screen {
    background: #fff;
    line-height: 0;
    overflow: hidden;
  }

  .iphone-screen :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Home indicator */
  .iphone-home-indicator {
    background: #fff;
    padding: 8px 0 6px;
    display: flex;
    justify-content: center;
    border-radius: 0 0 22px 22px;
  }

  .iphone-home-bar {
    width: 36%;
    height: 4px;
    background: #1a1a1a;
    border-radius: 2px;
    opacity: 0.2;
  }
</style>
