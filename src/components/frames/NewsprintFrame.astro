---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="newsprint-frame">
  <div class="newsprint-paper">
    <div class="newsprint-halftone"></div>
    <div class="newsprint-content">
      <slot />
    </div>
    <div class="newsprint-edge newsprint-edge-top"></div>
    <div class="newsprint-edge newsprint-edge-bottom"></div>
    <div class="newsprint-edge newsprint-edge-left"></div>
    <div class="newsprint-edge newsprint-edge-right"></div>
  </div>
  {title && (
    <div class="newsprint-caption">
      <span>{title}</span>
    </div>
  )}
</div>

<style>
  .newsprint-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .newsprint-paper {
    position: relative;
    background: #f5f0e0;
    padding: 16px;
    box-shadow:
      0 1px 4px rgba(0, 0, 0, 0.12),
      0 4px 12px rgba(0, 0, 0, 0.06);
    /* Slight rotation for natural feel */
    transform: rotate(-0.3deg);
  }

  /* Halftone dot texture overlay */
  .newsprint-halftone {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    pointer-events: none;
    z-index: 1;
    background-image: radial-gradient(circle, #000 0.5px, transparent 0.5px);
    background-size: 3px 3px;
  }

  .newsprint-content {
    position: relative;
    overflow: hidden;
    line-height: 0;
    z-index: 0;
    filter: contrast(1.05) saturate(0.85);
  }

  .newsprint-content :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Torn/rough edge effects */
  .newsprint-edge {
    position: absolute;
    z-index: 2;
    pointer-events: none;
  }

  .newsprint-edge-top {
    top: -2px;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      #f5f0e0 3%,
      transparent 5%,
      #f5f0e0 8%,
      transparent 11%,
      #f5f0e0 14%,
      transparent 18%,
      #f5f0e0 20%,
      transparent 24%,
      #f5f0e0 28%,
      transparent 30%,
      #f5f0e0 34%,
      transparent 38%,
      #f5f0e0 42%,
      transparent 45%,
      #f5f0e0 50%,
      transparent 53%,
      #f5f0e0 58%,
      transparent 62%,
      #f5f0e0 66%,
      transparent 70%,
      #f5f0e0 74%,
      transparent 78%,
      #f5f0e0 82%,
      transparent 86%,
      #f5f0e0 90%,
      transparent 94%,
      #f5f0e0 97%,
      transparent 100%
    );
  }

  .newsprint-edge-bottom {
    bottom: -2px;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(
      90deg,
      #f5f0e0 2%,
      transparent 6%,
      #f5f0e0 10%,
      transparent 13%,
      #f5f0e0 18%,
      transparent 22%,
      #f5f0e0 26%,
      transparent 30%,
      #f5f0e0 34%,
      transparent 39%,
      #f5f0e0 44%,
      transparent 48%,
      #f5f0e0 52%,
      transparent 56%,
      #f5f0e0 60%,
      transparent 65%,
      #f5f0e0 70%,
      transparent 74%,
      #f5f0e0 78%,
      transparent 82%,
      #f5f0e0 87%,
      transparent 91%,
      #f5f0e0 95%,
      transparent 100%
    );
  }

  .newsprint-edge-left {
    top: 0;
    left: -2px;
    bottom: 0;
    width: 3px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      #f5f0e0 5%,
      transparent 10%,
      #f5f0e0 18%,
      transparent 25%,
      #f5f0e0 35%,
      transparent 42%,
      #f5f0e0 55%,
      transparent 65%,
      #f5f0e0 75%,
      transparent 85%,
      #f5f0e0 92%,
      transparent 100%
    );
  }

  .newsprint-edge-right {
    top: 0;
    right: -2px;
    bottom: 0;
    width: 3px;
    background: linear-gradient(
      180deg,
      #f5f0e0 3%,
      transparent 8%,
      #f5f0e0 15%,
      transparent 22%,
      #f5f0e0 30%,
      transparent 40%,
      #f5f0e0 50%,
      transparent 60%,
      #f5f0e0 70%,
      transparent 80%,
      #f5f0e0 90%,
      transparent 95%,
      #f5f0e0 100%
    );
  }

  /* Yellowed aging effect around edges */
  .newsprint-paper::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 50%,
      rgba(180, 160, 100, 0.12) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .newsprint-caption {
    margin-top: 8px;
    transform: rotate(-0.3deg);
  }

  .newsprint-caption span {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-museum-muted);
    letter-spacing: 0.02em;
  }
</style>
