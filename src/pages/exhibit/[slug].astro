---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { getRoomBySlug } from '../../data/rooms';
import { getChannelBySlug } from '../../data/channels';

export async function getStaticPaths() {
  const allExhibits = await getCollection('exhibits');
  return allExhibits.map((exhibit) => ({
    params: { slug: exhibit.id },
    props: { exhibit, allExhibits },
  }));
}

interface Props {
  exhibit: any;
  allExhibits: any[];
}

const { exhibit, allExhibits } = Astro.props;
const { Content } = await render(exhibit);

const room = getRoomBySlug(exhibit.data.room);

// Prev/Next within same room
const roomExhibits = allExhibits
  .filter((e) => e.data.room === exhibit.data.room)
  .sort((a, b) => a.data.year - b.data.year);
const currentIndex = roomExhibits.findIndex((e) => e.id === exhibit.id);
const prevExhibit = currentIndex > 0 ? roomExhibits[currentIndex - 1] : null;
const nextExhibit = currentIndex < roomExhibits.length - 1 ? roomExhibits[currentIndex + 1] : null;

const shareUrl = `https://museumofgiving.org/exhibit/${exhibit.id}`;
const shareText = `${exhibit.data.title} — Museum of Giving`;
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`;
const linkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`;
---

<Layout
  title={`${exhibit.data.title} — Museum of Giving`}
  description={exhibit.data.notable}
  ogImage={exhibit.data.image}
>
  <main class="max-w-4xl mx-auto px-6">
    <!-- Back link -->
    <nav class="pt-8 pb-4">
      <a
        href={room ? `/room/${room.slug}` : '/'}
        class="text-museum-muted text-sm hover:text-museum-text transition-colors inline-flex items-center gap-1"
      >
        <span>&larr;</span> {room ? room.title : 'Museum'}
      </a>
    </nav>

    <!-- Exhibit -->
    <article class="pb-16">
      <!-- Media frame -->
      <div class="mb-10 flex justify-center">
        {exhibit.data.videoId ? (
          <div class="w-full max-w-3xl aspect-video">
            <iframe
              src={`https://www.youtube.com/embed/${exhibit.data.videoId}`}
              title={exhibit.data.title}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full rounded-sm"
            />
          </div>
        ) : (
          <div class="border border-museum-border p-2 sm:p-4 bg-museum-cream inline-block max-w-full">
            <img
              src={exhibit.data.image}
              alt={exhibit.data.title}
              class="max-w-full max-h-[70vh] object-contain"
              loading="eager"
            />
          </div>
        )}
      </div>

      <!-- Placard -->
      <div class="max-w-2xl mx-auto">
        <h1 class="font-display text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-4">
          {exhibit.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-museum-muted mb-6">
          <span class="font-medium text-museum-text">{exhibit.data.org}</span>
          <span>&middot;</span>
          <span>{exhibit.data.year}</span>
          {exhibit.data.country && (
            <>
              <span>&middot;</span>
              <span>{exhibit.data.country}</span>
            </>
          )}
        </div>

        <!-- Channel tags -->
        <div class="flex flex-wrap gap-2 mb-8">
          {exhibit.data.channels.map((ch: string) => {
            const channel = getChannelBySlug(ch);
            return (
              <a
                href={`/room/${ch}`}
                class="inline-block px-3 py-1 rounded-full text-xs font-medium border border-museum-border text-museum-muted hover:border-museum-text hover:text-museum-text transition-colors"
              >
                {channel?.label || ch}
              </a>
            );
          })}
        </div>

        <!-- Notable -->
        <div class="border-l-2 border-museum-gold pl-5 mb-8">
          <p class="text-museum-muted leading-relaxed italic">
            {exhibit.data.notable}
          </p>
        </div>

        <!-- Body content -->
        <div class="prose prose-sm max-w-none text-museum-text leading-relaxed mb-8">
          <Content />
        </div>

        <!-- Source attribution -->
        {exhibit.data.sourceAttribution && (
          <p class="text-xs text-museum-muted mb-8">
            Source: {exhibit.data.sourceUrl ? (
              <a
                href={exhibit.data.sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="underline hover:text-museum-text"
              >
                {exhibit.data.sourceAttribution}
              </a>
            ) : (
              exhibit.data.sourceAttribution
            )}
          </p>
        )}

        <!-- View Original -->
        {exhibit.data.sourceUrl && (
          <div class="mb-10">
            <a
              href={exhibit.data.sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-museum-accent hover:underline"
            >
              View Original
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        )}

        <!-- Share buttons -->
        <div class="flex items-center gap-4 border-t border-museum-border pt-8 mb-10">
          <span class="text-xs text-museum-muted uppercase tracking-widest">Share</span>
          <a
            href={linkedInUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-museum-muted hover:text-museum-text transition-colors"
            title="Share on LinkedIn"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href={twitterUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-museum-muted hover:text-museum-text transition-colors"
            title="Share on X"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <button
            id="copy-link-btn"
            class="text-museum-muted hover:text-museum-text transition-colors cursor-pointer"
            title="Copy link"
            data-url={shareUrl}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
            </svg>
          </button>
        </div>

        <!-- Prev/Next navigation -->
        <nav class="flex items-center justify-between border-t border-museum-border pt-8">
          {prevExhibit ? (
            <a
              href={`/exhibit/${prevExhibit.id}`}
              class="group text-sm text-museum-muted hover:text-museum-text transition-colors"
            >
              <span class="block text-xs uppercase tracking-widest mb-1">&larr; Previous</span>
              <span class="group-hover:underline">{prevExhibit.data.title}</span>
            </a>
          ) : (
            <div />
          )}
          {nextExhibit ? (
            <a
              href={`/exhibit/${nextExhibit.id}`}
              class="group text-sm text-museum-muted hover:text-museum-text transition-colors text-right"
            >
              <span class="block text-xs uppercase tracking-widest mb-1">Next &rarr;</span>
              <span class="group-hover:underline">{nextExhibit.data.title}</span>
            </a>
          ) : (
            <div />
          )}
        </nav>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<script>
  const btn = document.getElementById('copy-link-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url') || window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        btn.setAttribute('title', 'Copied!');
        setTimeout(() => btn.setAttribute('title', 'Copy link'), 2000);
      } catch {
        // Fallback
        const input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }
    });
  }
</script>
