---
import Layout from '../../layouts/Layout.astro';
import SubmitCTA from '../../components/SubmitCTA.astro';
import Footer from '../../components/Footer.astro';
import ExhibitCard from '../../components/ExhibitCard.astro';
import CommunitySubmissions from '../../components/CommunitySubmissions.tsx';
import { getCollection } from 'astro:content';

const allExhibits = await getCollection('exhibits');
const communityExhibits = allExhibits
  .filter((e) => e.data.community)
  .sort((a, b) => b.data.year - a.data.year);
---

<Layout title="Your Artifacts — Museum of Giving" description="Community-submitted fundraising artifacts from around the world.">
  <main class="max-w-7xl mx-auto px-6">
    <!-- Back link -->
    <nav class="pt-8 pb-4">
      <a
        href="/"
        class="text-museum-muted text-sm hover:text-museum-text transition-colors inline-flex items-center gap-1"
      >
        <span>&larr;</span> Museum
      </a>
    </nav>

    <!-- Header -->
    <header class="pb-12 pt-4 max-w-3xl">
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-6">
        Your Artifacts
      </h1>
      <p class="text-museum-muted text-lg sm:text-xl italic leading-relaxed">
        Fundraising history submitted by the community. Old donation pages, charity letters, and forgotten appeals — preserved here.
      </p>
    </header>

    <!-- Submit CTA — prominent -->
    <div class="mb-12">
      <SubmitCTA />
    </div>

    <!-- Community exhibits from MDX -->
    {communityExhibits.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 pb-8">
        {communityExhibits.map((exhibit) => (
          <ExhibitCard exhibit={exhibit} />
        ))}
      </div>
    )}

    <!-- Community submissions from Blob storage -->
    <CommunitySubmissions client:load />
  </main>

  <Footer />
</Layout>
