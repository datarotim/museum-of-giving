---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import RoomCard from '../components/RoomCard.astro';
import SubmitCTA from '../components/SubmitCTA.astro';
import Footer from '../components/Footer.astro';
import { rooms } from '../data/rooms';
import { channels } from '../data/channels';
---

<Layout>
  <main>
    <Hero />

    <!-- Explore by Era -->
    <section class="max-w-6xl mx-auto px-6 py-16">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-center mb-12 tracking-tight">
        EXPLORE BY ERA
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {rooms.sort((a, b) => a.order - b.order).map((room) => (
          <RoomCard
            slug={room.slug}
            title={room.title}
            era={room.era}
            description={room.description}
          />
        ))}
      </div>
    </section>

    <!-- Browse by Channel -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-center mb-12 tracking-tight">
        BROWSE BY CHANNEL
      </h2>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {channels.map((channel) => (
          <a
            href={`/room/${channel.slug}`}
            class="inline-block px-5 py-2.5 border border-museum-border rounded-full text-sm font-medium text-museum-text hover:bg-museum-text hover:text-white transition-colors"
          >
            {channel.label}
          </a>
        ))}
      </div>
    </section>

    <!-- Your Artifacts -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-center mb-12 tracking-tight">
        YOUR ARTIFACTS
      </h2>
      <SubmitCTA />
    </section>
  </main>

  <Footer />
</Layout>
